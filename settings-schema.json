{
    "location": {
        "type": "entry",
        "default": "auto",
        "description": "City name or 'auto' for IP geolocation",
        "tooltip": "Example: 'London' or 'Moscow,RU' or 'auto'"
    },
    "units": {
        "type": "combobox",
        "default": "metric",
        "description": "Temperature units",
        "options": {
            "metric": "Celsius °C",
            "imperial": "Fahrenheit °F"
        }
    },
    "language": {
        "type": "combobox",
        "default": "ru",
        "description": "Interface language",
        "options": {
            "en": "English",
            "ru": "Русский"
        }
    },
    "refresh-interval": {
        "type": "spinbutton",
        "default": 10,
        "min": 2,
        "max": 60,
        "units": "minutes",
        "step": 1,
        "description": "Refresh interval"
    },
    "theme": {
        "type": "combobox",
        "default": "auto",
        "description": "Colour theme",
        "options": {
            "auto": "Auto (adapts to weather/sky)",
            "glass": "Glass (frosted, always light)",
            "dark": "Dark (night mode)",
            "warm": "Warm (golden/amber tones)",
            "cool": "Cool (blue/teal tones)",
            "nature": "Nature (green/earth tones)"
        }
    },
    "show-forecast": {
        "type": "switch",
        "default": true,
        "description": "Show forecast strip"
    },
    "forecast-type": {
        "type": "combobox",
        "default": "daily",
        "description": "Forecast mode",
        "options": {
            "daily": "Daily (3-5 days)",
            "hourly": "Hourly (up to 24h)"
        },
        "dependency": "show-forecast"
    },
    "forecast-hours": {
        "type": "spinbutton",
        "default": 6,
        "min": 3,
        "max": 24,
        "units": "hours",
        "step": 3,
        "description": "Hourly forecast range",
        "dependency": "show-forecast"
    },
    "show-background": {
        "type": "switch",
        "default": true,
        "description": "Show background gradient and glass panel"
    },
    "show-humidity": {
        "type": "switch",
        "default": true,
        "description": "Show humidity"
    },
    "show-wind": {
        "type": "switch",
        "default": true,
        "description": "Show wind speed"
    },
    "show-pressure": {
        "type": "switch",
        "default": true,
        "description": "Show atmospheric pressure"
    },
    "opacity": {
        "type": "spinbutton",
        "default": 70,
        "min": 20,
        "max": 100,
        "units": "%",
        "step": 5,
        "description": "Panel opacity"
    },
    "width": {
        "type": "spinbutton",
        "default": 350,
        "min": 200,
        "max": 600,
        "units": "px",
        "step": 10,
        "description": "Desklet width"
    },
    "__provider__": {
        "type": "section",
        "description": "\u2699\ufe0f Weather Source"
    },
    "api-provider": {
        "type": "combobox",
        "default": "met-norway",
        "description": "Provider",
        "options": {
            "open-meteo": "Open-Meteo",
            "met-norway": "MET Norway (yr.no)"
        }
    }
}

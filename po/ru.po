#. metadata.json->name
msgid "Animated Weather"
msgstr "Анимированная погода"

#. metadata.json->description
msgid "Real-time animated weather desklet with live particle effects — rain, snow, clouds, stars, and dynamic sky gradients"
msgstr "Десклет погоды с живыми анимациями — дождь, снег, облака, звёзды и динамическое небо"

#. settings-schema.json->api-key->description
msgid "OpenWeatherMap API Key"
msgstr "API ключ OpenWeatherMap"

#. settings-schema.json->api-key->tooltip
msgid "Get your free key at https://openweathermap.org/api (free tier: 60 calls/min)"
msgstr "Получите бесплатный ключ на https://openweathermap.org/api (бесплатно: 60 запросов/мин)"

#. settings-schema.json->location->description
msgid "City name or 'auto' for IP geolocation"
msgstr "Название города или 'auto' для определения по IP"

#. settings-schema.json->location->tooltip
msgid "Example: 'London' or 'Moscow,RU' or 'auto'"
msgstr "Пример: 'Москва' или 'Moscow,RU' или 'auto'"

#. settings-schema.json->units->description
msgid "Temperature units"
msgstr "Единицы температуры"

#. settings-schema.json->language->description
msgid "Interface language"
msgstr "Язык интерфейса"

#. settings-schema.json->refresh-interval->description
msgid "Refresh interval"
msgstr "Интервал обновления"

#. settings-schema.json->theme->description
msgid "Colour theme"
msgstr "Цветовая тема"

#. settings-schema.json->show-forecast->description
msgid "Show hourly forecast strip"
msgstr "Показывать почасовой прогноз"

#. settings-schema.json->forecast-hours->description
msgid "Forecast range"
msgstr "Диапазон прогноза"

#. settings-schema.json->opacity->description
msgid "Panel opacity"
msgstr "Прозрачность панели"

#. settings-schema.json->width->description
msgid "Desklet width"
msgstr "Ширина десклета"
